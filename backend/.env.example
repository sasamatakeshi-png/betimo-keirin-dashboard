# Betimo KEIRIN Dashboard — backend 環境変数サンプル
# このファイルをコピーして .env を作成し、実際の値を設定すること。
# .env は .gitignore 済み（コミットしない）。

# PostgreSQL 接続文字列
# 形式: postgresql+psycopg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=

# Phase 1 の環境変数パスワード認証
APP_PASSWORD=

# Anthropic API キー
ANTHROPIC_API_KEY=

# AI 分析で使う Claude モデル（未設定なら既定 claude-opus-4-8）
ANALYSIS_MODEL=

# YouTube Data API v3 キー（チャンネル統計＝総登録者数/総再生数の取得用）
# 未設定でもアプリは起動する（その場合ホームの該当カードは CSV 合算値で表示）。
YOUTUBE_API_KEY=

# フロントエンドの許可オリジン（CORS。未設定なら既定 http://localhost:3000）
FRONTEND_ORIGIN=http://localhost:3000
